generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
  TRAINER
}

enum LicenseType {
  LMV
  MCWG
  BOTH
  HMV
}

enum StudentStatus {
  ENROLLED
  TRAINING
  TEST_SCHEDULED
  COMPLETED
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
}

enum TestStatus {
  PENDING
  PASSED
  FAILED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id               String          @id @default(cuid())
  studentId        String          @unique // e.g., STU-001
  name             String
  phoneNumber      String
  address          String?         
  totalFee         Float           @default(0)
  dateOfBirth      DateTime?
  idProofNumber    String?
  registrationDate DateTime        @default(now())
  licenseType      LicenseType
  status           StudentStatus   @default(ENROLLED)
  
  // Relations
  assignedTrainerId String?
  assignedTrainer   Trainer?       @relation(fields: [assignedTrainerId], references: [id], onDelete: SetNull)
  
  assignedVehicleId String?
  assignedVehicle   Vehicle?       @relation(fields: [assignedVehicleId], references: [id])

  feePayments      FeePayment[]
  additionalClasses AdditionalClass[]
  classSchedules   ClassSchedule[]
  testSchedules    TestSchedule[]
  documents        Document[]

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model AdditionalClass {
  id            String        @id @default(cuid())
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  licenseType   LicenseType
  amount        Float
  paymentDate   DateTime      @default(now())
  paymentMethod PaymentMethod
  receiptNumber String        @unique // e.g., ADD-001
  notes         String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model FeePayment {
  id            String        @id @default(cuid())
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  totalFee      Float
  paidAmount    Float
  balance       Float         // Can be calculated, but good to store
  paymentDate   DateTime      @default(now())
  paymentMethod PaymentMethod
  receiptNumber String        @unique // e.g., REC-001

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Trainer {
  id            String          @id @default(cuid())
  name          String
  phone         String
  licenseNumber String
  experience    Int?            // in years
  
  // Relations
  assignedVehicleId String?
  assignedVehicle   Vehicle?      @relation(fields: [assignedVehicleId], references: [id])
  
  students        Student[]
  classSchedules  ClassSchedule[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Vehicle {
  id                 String          @id @default(cuid())
  vehicleType        String          // e.g., Car, Bike
  registrationNumber String          @unique
  insuranceExpiry    DateTime?
  pollutionExpiry    DateTime?
  serviceReminder    DateTime?
  
  // Relations
  students        Student[]
  trainers        Trainer[]
  classSchedules  ClassSchedule[]
  testSchedules   TestSchedule[]

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model ClassSchedule {
  id          String   @id @default(cuid())
  date        DateTime
  startTime   DateTime
  endTime     DateTime
  
  // Relations
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  trainerId   String
  trainer     Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])

  attended    Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TestSchedule {
  id          String     @id @default(cuid())
  testDate    DateTime
  
  // Relations
  studentId   String
  student     Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  vehicleId   String?
  vehicle     Vehicle?   @relation(fields: [vehicleId], references: [id])

  status      TestStatus @default(PENDING)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Document {
  id           String   @id @default(cuid())
  documentType String   // e.g., ID_PROOF, LEARNER_LICENSE, PHOTO
  fileUrl      String   // Path or URL to the uploaded file
  
  // Relations
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
